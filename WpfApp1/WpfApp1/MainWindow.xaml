<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Sample Grid" Height="450" Width="500">
    <Grid x:Name="myGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="75" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>
        <Button Grid.Row="5" Grid.Column="1" Content="Add TODO" Margin="5" Click="OnBtn1Click" BorderBrush="#FFD06565" Background="#FF1BA91E" FontWeight="Bold" FontSize="16"/>
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="todoStackPanel" Background="#FFD8E2E2" />
        </ScrollViewer>
        <TextBox x:Name="txtTodo" Grid.Column="1" Grid.Row="3" Background="#FFD8E2E2" Foreground="#FF131313" FontWeight="Bold" />

    </Grid>
</Window>
